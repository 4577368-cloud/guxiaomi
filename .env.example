# Local API address used by build-time env.js generation.
# In local static preview, the frontend also falls back to http://localhost:8123.
ANALYSIS_API_BASE=http://localhost:8123

# LLM services used by stock analysis, deep diagnosis, and Ziwei chat.
# Frontend sends only model1/model2/model3; secrets stay on the API server.
LLM_DEFAULT_MODEL_KEY=model2

LLM_MODEL1_LABEL=MiniMax
LLM_MODEL1_BASE_URL=
LLM_MODEL1_API_KEY=
LLM_MODEL1_MODEL_ID=

LLM_MODEL2_LABEL=Gemma
LLM_MODEL2_BASE_URL=
LLM_MODEL2_API_KEY=
LLM_MODEL2_MODEL_ID=

LLM_MODEL3_LABEL=Deepseek
LLM_MODEL3_BASE_URL=
LLM_MODEL3_API_KEY=
LLM_MODEL3_MODEL_ID=

# Optional market/news enrichments. Leave blank if you do not have keys.
ALPHA_VANTAGE_API_KEY=
GNEWS_API_KEY=

# Optional proxies for server-side data/news fetching.
GTIMG_HTTP_PROXY_TEMPLATE=
RSS_PROXY_URL=

# Optional CORS allowlist for deployed API, comma-separated.
ALLOWED_ORIGINS=

# Vercel Postgres / Neon connection string (free tier)
# Format: postgres://user:password@host:port/database?sslmode=require
POSTGRES_URL=
